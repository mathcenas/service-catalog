# Supabase project credentials (baked into the build at image build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
# Works with either the classic JWT anon key or the new `sb_publishable_...` key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Host port exposed by docker-compose (optional)
APP_PORT=8080

# Name of the external Docker network that Nginx Proxy Manager is attached to.
# Create it once with: docker network create npm_proxy
# and attach your NPM container to it so it can reach the app by the service name "client-manager".
NPM_NETWORK=npm_proxy
