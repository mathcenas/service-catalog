# Copiar este archivo a ".env" en cada VPS y completar según corresponda.
# El .env NUNCA se sube al repo (ver .gitignore).

# --- Identificación ---
# Nombre para identificar este VPS en logs, nombre de archivo y mensajes a Kuma.
# Default: hostname del servidor.
HOST_TAG=nombre-servidor

# --- Origen ---
# Directorios a respaldar. Van TODOS DENTRO DE LAS MISMAS COMILLAS, separados por espacio.
# Correcto:   SRC_DIRS="/srv /opt/otra-app"
# Incorrecto: SRC_DIRS="/srv" "/opt/otra-app"   <- esto rompe el archivo .env
SRC_DIRS="/srv"

# Patrones a excluir del tar (separados por espacio). Ej: cachés, tmp, logs pesados.
EXCLUDE_PATTERNS="*/node_modules/* */.cache/* */tmp/*"

# --- Postgres (opcional) ---
# Nombres de contenedores docker de Postgres a dumpear antes de tarear /srv.
# Dejar vacío si no aplica. Ej: "dbpgsql" o "db1 db2"
PG_CONTAINERS=""

# --- Staging / retención local ---
# Carpeta local donde se arma y/o queda guardado el .tar.gz
BACKUP_ROOT="/var/backups/vps-kuma"

# Días de retención de backups locales (los más viejos se borran)
RETENTION_DAYS=7

# --- Destino ---
# local  -> se queda solo en BACKUP_ROOT
# rsync  -> se envía por ssh a otro host (requiere ssh-key sin passphrase o agente)
# rclone -> se envía a un remote configurado con "rclone config" (S3, Backblaze, etc.)
DEST_TYPE="local"

# Si DEST_TYPE=rsync
RSYNC_DEST="usuario@servidor-backup:/backups/vps1"
RSYNC_SSH_KEY="/root/.ssh/id_ed25519_backup"

# Si DEST_TYPE=rclone
RCLONE_REMOTE="miremote:bucket-backups/vps1"

# --- Logging ---
# Por default el log queda en backup.log, en el mismo directorio que el script.
# No hace falta configurar nada; solo descomentar si querés otra ubicación.
# LOG_FILE="/var/log/vps-backup.log"

# --- Uptime Kuma ---
# URL completa del Push Monitor creado en Kuma (Monitor tipo "Push").
# Pegá SOLO la base, sin parámetros:
# https://kuma.midominio.com/api/push/AbCdEfGhIj
KUMA_PUSH_URL=""

# --- Email (Resend) ---
# API key de Resend (https://resend.com/api-keys)
RESEND_API_KEY=""

# Remitente. Tiene que ser un dominio verificado en Resend.
RESEND_FROM="backups@midominio.com"

# Destinatario(s). Una sola dirección o varias separadas por coma.
RESEND_TO="admin@midominio.com"

# Cuándo mandar mail: true/false
EMAIL_ON_SUCCESS="true"
EMAIL_ON_FAILURE="true"

# --- Supabase ingest (reporte al panel de backups) ---
# Obtener estos valores desde el servicio en el panel de administración.
INGEST_URL="https://PROYECTO.supabase.co/functions/v1/ingest-backup"
SUPABASE_ANON_KEY="REEMPLAZAR"
INGEST_SECRET="REEMPLAZAR"
SERVICE_ID="REEMPLAZAR-CON-UUID-DEL-SERVICIO"
