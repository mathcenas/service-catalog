# =============================================================
# backup.env.example — Configuración para backup.sh
# Copiar a .env en la misma carpeta que backup.sh y ajustar valores
# Permisos: chmod 600 .env
# =============================================================

# ---- Identificación del servidor ----
HOST_TAG="mi-servidor"          # Nombre que aparece en logs y notificaciones

# ---- Directorios a respaldar ----
# Separados por espacio. Se comprimen todos en un solo .tar.gz
SRC_DIRS="/srv /etc/nginx /home/usuario"

# Patrones a excluir del tar (separados por espacio)
# Ejemplo: EXCLUDE_PATTERNS="*.log node_modules .git"
EXCLUDE_PATTERNS=""

# ---- Destino del backup ----
BACKUP_ROOT="/var/backups/vps"          # Carpeta local donde se guarda el .tar.gz
RETENTION_DAYS=7                        # Días que se mantienen los backups locales
DEST_TYPE="local"                       # local | rsync | rclone

# Si DEST_TYPE=rsync:
RSYNC_DEST="usuario@nas:/volume1/backups/mi-servidor"
RSYNC_SSH_KEY="/root/.ssh/id_ed25519_backup"

# Si DEST_TYPE=rclone:
RCLONE_REMOTE="s3-backups:mi-bucket/vps"

# ---- Postgres (Docker) ----
# Nombres de contenedores Docker con Postgres a dumpear, separados por espacio
# Dejar vacío si no aplica
PG_CONTAINERS=""

# ---- Uptime Kuma (push monitor) ----
KUMA_PUSH_URL=""
# Ejemplo: https://kuma.midominio.com/api/push/AbCdEfGh?status=up&msg=OK&ping=

# ---- Supabase ingest (reporte al panel de backups) ----
INGEST_URL="https://PROYECTO.supabase.co/functions/v1/ingest-backup"
SUPABASE_ANON_KEY="REEMPLAZAR_CON_SUPABASE_ANON_KEY"
INGEST_SECRET="REEMPLAZAR_CON_INGEST_SECRET_DEL_SERVICIO"
SERVICE_ID="REEMPLAZAR_CON_UUID_DEL_SERVICIO"

# ---- Notificaciones por mail (Resend) ----
RESEND_API_KEY=""
RESEND_FROM="Backups <backups@midominio.com>"
RESEND_TO="admin@midominio.com"
EMAIL_ON_SUCCESS=false
EMAIL_ON_FAILURE=true
